{
  "name": "luxcoder",
  "version": "0.1.0",
  "description": "The next gen ai software with general agents",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --filter='@luxcoder/electron' dev",
    "electron:dev": "bun run --filter='@luxcoder/electron' dev",
    "electron:build": "bun run --filter='@luxcoder/electron' build",
    "electron:start": "bun run --filter='@luxcoder/electron' start",
    "build": "bun run --filter='*' build",
    "typecheck": "bun run --filter='*' typecheck",
    "test": "bun test",
    "sync:check": "bun scripts/upstream-sync/check.ts",
    "sync:apply-renames": "bun scripts/upstream-sync/apply-renames.ts",
    "sync:weekly": "bun scripts/upstream-sync/weekly-sync.ts"
  },
  "devDependencies": {
    "@rollup/rollup-darwin-x64": "4.56.0",
    "@types/bun": "latest",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "dompurify": "^3.4.2",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "jotai": "^2.17.1"
  },
  "overrides": {
    "@anthropic-ai/claude-agent-sdk": "0.3.201",
    "@anthropic-ai/claude-agent-sdk-darwin-arm64": "0.3.201",
    "@anthropic-ai/claude-agent-sdk-darwin-x64": "0.3.201",
    "@anthropic-ai/claude-agent-sdk-win32-arm64": "0.3.201",
    "@anthropic-ai/claude-agent-sdk-win32-x64": "0.3.201",
    "@earendil-works/pi-agent-core": "0.80.9",
    "@earendil-works/pi-ai": "0.80.9",
    "@earendil-works/pi-coding-agent": "0.80.9",
    "@earendil-works/pi-tui": "0.80.9"
  },
  "patchedDependencies": {
    "@earendil-works/pi-ai@0.80.9": "patches/@earendil-works%2Fpi-ai@0.80.9.patch"
  }
}
