{
  "$comment": "Proma → LuxAgents 同步后 rename / 门禁规则。apply-renames 与 sync:check 共用。",
  "skipDirNames": [
    ".git",
    "node_modules",
    "dist",
    "out",
    "output",
    ".superpowers",
    ".playwright-mcp",
    ".cursor",
    "storage",
    "coverage"
  ],
  "skipFileGlobs": [
    "**/bun.lock",
    "**/*.lock",
    "**/*.png",
    "**/*.jpg",
    "**/*.jpeg",
    "**/*.gif",
    "**/*.webp",
    "**/*.ico",
    "**/*.icns",
    "**/*.woff",
    "**/*.woff2",
    "**/*.ttf",
    "**/*.eot",
    "**/*.mp4",
    "**/*.zip",
    "**/*.dmg",
    "**/*.exe",
    "**/*.node",
    "**/*.pdf"
  ],
  "allowlistGlobs": [
    "**/migration-service.ts",
    "**/scripts/upstream-sync/**",
    "**/release-notes/**",
    "**/docs/**",
    "**/tutorial/**"
  ],
  "warnOnlyGlobs": [
    "CLAUDE.md",
    "AGENTS.md",
    "README.md",
    "README.en.md",
    "**/docs/plans/**"
  ],
  "replacements": [
    { "from": "@anthropic-ai/Codex-agent-sdk", "to": "@anthropic-ai/claude-agent-sdk" },
    { "from": "Codex-agent-sdk", "to": "claude-agent-sdk" },
    { "from": "@proma/", "to": "@luxagents/" },
    { "from": "~/.proma", "to": "~/.luxagents" },
    { "from": ".proma-dev", "to": ".luxagents-dev" },
    { "from": "/.proma/", "to": "/.luxagents/" },
    { "from": "\"@proma/", "to": "\"@luxagents/" }
  ],
  "forbiddenPatterns": [
    {
      "id": "pkg-scope",
      "regex": "@proma/",
      "message": "残留 @proma/ 包作用域，应改为 @luxagents/"
    },
    {
      "id": "home-proma",
      "regex": "~/.proma",
      "message": "残留 ~/.proma 路径，应改为 ~/.luxagents"
    },
    {
      "id": "dot-proma",
      "regex": "(^|[\"'`\\s])/\\.proma(/|[\"'`\\s]|$)|\\.proma-dev",
      "message": "残留 .proma / .proma-dev 路径片段"
    },
    {
      "id": "codex-sdk-typo",
      "regex": "Codex-agent-sdk",
      "message": "错误 SDK 包名 Codex-agent-sdk，应改为 claude-agent-sdk"
    }
  ],
  "sdkPlatformPackages": [
    "@anthropic-ai/claude-agent-sdk-darwin-arm64",
    "@anthropic-ai/claude-agent-sdk-darwin-x64",
    "@anthropic-ai/claude-agent-sdk-win32-x64",
    "@anthropic-ai/claude-agent-sdk-win32-arm64"
  ],
  "luxOnlySkills": [
    "luxagents-coach",
    "guizang-ppt-skill"
  ]
}
